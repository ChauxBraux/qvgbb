---
import Layout from '../layouts/Layout.astro';

// To populate this gallery, drop images into /public/images/gallery/
// and reference them here. We'll wire it up to glob the folder later.
const photos = [
  { src: '/images/gallery/placeholder-1.jpg', alt: 'Team huddle', caption: 'Pre-game huddle, Dec 2025' },
  { src: '/images/gallery/placeholder-2.jpg', alt: 'Senior night', caption: 'Senior Night 2025' },
  { src: '/images/gallery/placeholder-3.jpg', alt: 'Tournament', caption: 'Holiday Tournament' },
];
---
<Layout title="Gallery" description="Photos from the QV Girls Basketball season.">
  <section class="bg-qvblack text-white py-16">
    <div class="container-narrow">
      <h1 class="font-display text-4xl md:text-6xl uppercase">Gallery</h1>
      <p class="text-lg text-gray-300 max-w-2xl mt-4">Moments from the season. For the latest photos and game highlights, follow the team on Instagram.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-narrow">
      <div class="flex justify-end mb-6">
        <a href="https://www.instagram.com/qvgirlsbasketballboosters/" target="_blank" rel="noopener" class="btn-secondary">
          Follow on Instagram &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {photos.map(p => (
          <figure class="group">
            <div class="aspect-square bg-gray-100 overflow-hidden border-2 border-qvblack group-hover:border-qvgold transition-colors">
              <img src={p.src} alt={p.alt} class="w-full h-full object-cover"/>
            </div>
            {p.caption && <figcaption class="text-sm text-gray-600 mt-2 font-display uppercase tracking-wider text-xs">{p.caption}</figcaption>}
          </figure>
        ))}
      </div>
      <p class="text-center text-sm text-gray-500 mt-8">Add real photos to <code class="bg-gray-100 px-2 py-1 rounded">/public/images/gallery/</code> and update the photos array in <code class="bg-gray-100 px-2 py-1 rounded">src/pages/gallery.astro</code>.</p>
    </div>
  </section>
</Layout>
