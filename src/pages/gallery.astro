---
import Layout from '../layouts/Layout.astro';

// To populate this gallery, drop images into /public/images/gallery/
// and reference them here. We'll wire it up to glob the folder later.
const photos = [
  { src: '/images/gallery/team-photo.jpg', alt: 'QV Girls Basketball official team photo in the Quaker Valley gym', caption: 'Official Team Photo, 2025-2026 Season' },
  { src: '/images/gallery/team-huddle.jpg', alt: 'QV Girls Basketball team in a huddle on the court during Senior Night', caption: 'Team Huddle, Senior Night' },
  { src: '/images/gallery/mimi-all-time-scorer.jpg', alt: 'Mimi Thiero holding the all-time leading scorer sign at center court', caption: 'Mimi Thiero, All-Time Leading Scorer' },
  { src: '/images/gallery/senior-night.jpg', alt: 'Seniors Mia, Mimi, and Lucy holding signs on Senior Night with black and gold balloons', caption: 'Senior Night: Mia, Mimi, and Lucy' },
  { src: '/images/gallery/game-action.jpg', alt: 'QV player #20 bringing the ball up the court during a game', caption: 'Game Action' },
  { src: '/images/gallery/teammates-celebrate.jpg', alt: 'QV players #20 and #24 celebrating during a game', caption: 'Teammates Celebrate' },
  { src: '/images/gallery/high-fives-youth.jpg', alt: 'QV players high-fiving young fans during pregame introductions', caption: 'High Fives with Young Fans' },
  { src: '/images/gallery/young-fans.jpg', alt: 'Young QV fans in the stands holding signs with player names', caption: 'QV Fans Show Up' },
  { src: '/images/gallery/pregame-warmups.jpg', alt: 'QV players warming up before an away game', caption: 'Pregame Warmups' },
  { src: '/images/gallery/tournament-team-photo.jpg', alt: 'QV Girls Basketball team posing with a plaque at a tournament', caption: 'Tournament Team Photo' },
  { src: '/images/gallery/team-postgame.jpg', alt: 'QV team posing together after a tournament game', caption: 'Postgame at Tournament' },
  { src: '/images/gallery/team-creative-shot.jpg', alt: 'QV team creative photo with Mimi Thiero hanging from the rim', caption: 'Team Photo, Preseason' },
  { src: '/images/gallery/florida-trip.jpg', alt: 'QV Girls Basketball team at Universal Studios during their Florida trip', caption: 'Florida Trip, 2025' },
];
---
<Layout title="Gallery" description="Photos from the QV Girls Basketball season.">
  <section class="bg-qvblack text-white py-16">
    <div class="container-narrow">
      <h1 class="font-display text-4xl md:text-6xl uppercase">Gallery</h1>
      <p class="text-lg text-gray-300 max-w-2xl mt-4">Moments from the season. For the latest photos and game highlights, follow the team on Instagram.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-narrow">
      <div class="flex justify-end mb-6">
        <a href="https://www.instagram.com/qvgirlsbasketballboosters/" target="_blank" rel="noopener" class="btn-secondary">
          Follow on Instagram &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {photos.map(p => (
          <figure class="group">
            <div class="aspect-square bg-gray-100 overflow-hidden border-2 border-qvblack group-hover:border-qvgold transition-colors">
              <img src={p.src} alt={p.alt} class="w-full h-full object-cover"/>
            </div>
            {p.caption && <figcaption class="text-sm text-gray-600 mt-2 font-display uppercase tracking-wider text-xs">{p.caption}</figcaption>}
          </figure>
        ))}
      </div>
    </div>
  </section>
</Layout>
