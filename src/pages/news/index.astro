---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---
<Layout title="News & Recaps" description="Game recaps, team news, and updates from QV Girls Basketball.">
  <section class="bg-qvblack text-white py-16">
    <div class="container-narrow">
      <h1 class="font-display text-4xl md:text-6xl uppercase">News &amp; Recaps</h1>
      <p class="text-lg text-gray-300 max-w-2xl mt-4">Game recaps, team milestones, and updates from the program.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-narrow">
      {posts.length === 0 ? (
        <p class="text-gray-600">No posts yet. Check back soon.</p>
      ) : (
        <div class="space-y-8">
          {posts.map(post => (
            <article class="border-b border-gray-200 pb-8 last:border-0">
              <div class={`flex flex-col ${post.data.image ? 'md:flex-row md:gap-6' : ''}`}>
                {post.data.image && (
                  <a href={`/news/${post.slug}`} class="shrink-0 mb-4 md:mb-0">
                    <img src={post.data.image} alt="" class="w-full md:w-48 h-32 object-cover object-top border border-gray-200" />
                  </a>
                )}
                <div>
                  <p class="text-xs uppercase tracking-wider text-gray-500 font-display">
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                    <span class="mx-2">&middot;</span>
                    <span>{post.data.author}</span>
                  </p>
                  <h2 class="font-display text-2xl md:text-3xl mt-2 mb-3">
                    <a href={`/news/${post.slug}`} class="hover:text-qvgold-700">{post.data.title}</a>
                  </h2>
                  <p class="text-gray-700 mb-4">{post.data.excerpt}</p>
                  <a href={`/news/${post.slug}`} class="font-display uppercase tracking-wider text-sm text-qvblack hover:text-qvgold-700">Read more &rarr;</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
