---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Donate" description="Support QV Girls Basketball through Venmo or by becoming a corporate sponsor.">
  <section class="bg-qvblack text-white py-16">
    <div class="container-narrow">
      <p class="text-qvgold font-display uppercase tracking-[0.3em] text-sm mb-3">Support the Program</p>
      <h1 class="font-display text-4xl md:text-6xl uppercase">Donate</h1>
      <p class="text-lg text-gray-300 max-w-2xl mt-4">Every dollar goes directly to the girls. Gear, tournament fees, team meals, senior nights, and the things that make a season feel like a season.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container-narrow grid md:grid-cols-2 gap-12 items-start">
      <!-- Venmo -->
      <div class="border-2 border-qvblack p-8">
        <h2 class="font-display text-2xl uppercase mb-3">Give via Venmo</h2>
        <p class="text-gray-700 mb-6">The fastest way to support us. Scan the QR code or search for our handle on Venmo.</p>
        <div class="bg-gray-50 p-6 flex flex-col items-center">
          <!-- Replace with actual Venmo QR -->
          <img src="/images/venmo-qr.jpg" alt="QV Girls Basketball Boosters Venmo QR code" class="w-56 mb-4 bg-white p-2"/>
          <p class="font-display font-semibold text-lg">@qvgirlsbasketball</p>
        </div>
        <p class="text-xs text-gray-500 mt-4">QV Girls Basketball Boosters is a registered 501(c)(3). Your gift may be tax-deductible. Consult your tax advisor.</p>
      </div>

      <!-- Sponsor tiers -->
      <div>
        <h2 class="font-display text-2xl uppercase mb-3">Become a Sponsor</h2>
        <p class="text-gray-700 mb-6">Local businesses keep this program running. Sponsorship includes recognition on our website, in the gym, and in season-end communications.</p>
        <div class="space-y-3">
          <div class="border-l-4 border-qvgold bg-gray-50 p-4">
            <p class="font-display font-semibold uppercase">Elite Team - $1,500</p>
            <ul class="text-sm text-gray-600 mt-1 list-disc list-inside space-y-0.5">
              <li>Personalized thank you letter and team photo</li>
              <li>Company logo on team shirts for travel tournament</li>
              <li>Recognition on social media</li>
              <li>Company banner displayed in gym</li>
              <li>PA announcement at all home games</li>
              <li>Logo in gameday programs</li>
              <li>Season pass to all home games</li>
            </ul>
          </div>
          <div class="border-l-4 border-qvgold-600 bg-gray-50 p-4">
            <p class="font-display font-semibold uppercase">Champion - $1,000</p>
            <ul class="text-sm text-gray-600 mt-1 list-disc list-inside space-y-0.5">
              <li>Company logo on team shirts for travel tournament</li>
              <li>Recognition on social media</li>
              <li>Company banner displayed in gym</li>
              <li>PA announcement at all home games</li>
              <li>Logo in gameday programs</li>
              <li>Season pass to all home games</li>
            </ul>
          </div>
          <div class="border-l-4 border-qvgold-700 bg-gray-50 p-4">
            <p class="font-display font-semibold uppercase">Game Changer - $500</p>
            <ul class="text-sm text-gray-600 mt-1 list-disc list-inside space-y-0.5">
              <li>Recognition on social media</li>
              <li>Company banner displayed in gym</li>
              <li>PA announcement at home games</li>
              <li>Logo in gameday programs</li>
              <li>Season pass to all home games</li>
            </ul>
          </div>
          <div class="border-l-4 border-qvblack bg-gray-50 p-4">
            <p class="font-display font-semibold uppercase">All Star - $250</p>
            <ul class="text-sm text-gray-600 mt-1 list-disc list-inside space-y-0.5">
              <li>Recognition on social media</li>
              <li>Company banner displayed in gym</li>
              <li>Logo in gameday programs</li>
              <li>Season pass to all home games</li>
            </ul>
          </div>
          <div class="border-l-4 border-gray-400 bg-gray-50 p-4">
            <p class="font-display font-semibold uppercase">Super Fan - $100</p>
            <ul class="text-sm text-gray-600 mt-1 list-disc list-inside space-y-0.5">
              <li>Recognition on social media</li>
            </ul>
          </div>
        </div>
        <a href="/contact" class="btn-secondary mt-6">Talk to Us About Sponsorship</a>
      </div>
    </div>
  </section>
</Layout>
