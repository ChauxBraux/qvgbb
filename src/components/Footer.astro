---
const year = new Date().getFullYear();
---
<footer class="bg-qvblack text-white mt-20">
  <div class="container-narrow py-12 grid md:grid-cols-3 gap-8">
    <div>
      <h3 class="text-qvgold font-display text-lg uppercase tracking-wider mb-3">QV Girls Basketball Boosters</h3>
      <p class="text-sm text-gray-300">Supporting Quaker Valley girls basketball through sponsorships, fundraising, and community engagement.</p>
      <p class="text-xs text-gray-400 mt-3">A registered 501(c)(3) nonprofit organization.</p>
    </div>
    <div>
      <h4 class="text-qvgold font-display text-sm uppercase tracking-wider mb-3">Quick Links</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/sponsors" class="hover:text-qvgold">Our Sponsors</a></li>
        <li><a href="/donate" class="hover:text-qvgold">Donate</a></li>
        <li><a href="/schedule" class="hover:text-qvgold">Schedule</a></li>
        <li><a href="/contact" class="hover:text-qvgold">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-qvgold font-display text-sm uppercase tracking-wider mb-3">Follow the Team</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="https://www.instagram.com/qvgirlsbasketballboosters/" target="_blank" rel="noopener" class="hover:text-qvgold">Instagram</a></li>
        <li><a href="https://www.facebook.com/profile.php?id=61574146196530" target="_blank" rel="noopener" class="hover:text-qvgold">Facebook</a></li>
        <li><a href="https://x.com/QVBballBoosters" target="_blank" rel="noopener" class="hover:text-qvgold">X / Twitter</a></li>
        <li><a href="https://fan.hudl.com/usa/pa/leetsdale/organization/20945/quaker-valley-high-school/team/135913/girls-varsity-basketball" target="_blank" rel="noopener" class="hover:text-qvgold">Hudl</a></li>
        <li><a href="https://www.maxpreps.com/pa/leetsdale/quaker-valley-quakers/basketball/girls/" target="_blank" rel="noopener" class="hover:text-qvgold">MaxPreps</a></li>
        <li><a href="https://qvquakers.org/" target="_blank" rel="noopener" class="hover:text-qvgold">QV Athletics</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-qvblack-700">
    <div class="container-narrow py-4 text-xs text-gray-400 flex flex-col md:flex-row justify-between gap-2">
      <span>&copy; {year} QV Girls Basketball Boosters</span>
      <span>Sewickley, PA</span>
    </div>
  </div>
</footer>
